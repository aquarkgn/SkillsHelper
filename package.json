{
  "name": "huhaa-myskills",
  "version": "0.1.3",
  "private": false,
  "description": "Local skill / plugin / MCP aggregation hub. Browse all your AI agent skills at http://localhost:11520.",
  "license": "MIT",
  "homepage": "https://github.com/aquarkgn/HuHaa-MySkills#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aquarkgn/HuHaa-MySkills.git"
  },
  "bugs": {
    "url": "https://github.com/aquarkgn/HuHaa-MySkills/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "huhaa-myskills": "service/bin/huhaa-myskills.mjs"
  },
  "files": [
    "service/bin/",
    "service/config/",
    "service/packages/scanner/package.json",
    "service/packages/scanner/src/",
    "service/packages/server/package.json",
    "service/packages/server/src/",
    "service/packages/web/dist/",
    "service/scripts/",
    "docs/",
    "README.md",
    "LICENSE",
    "install-and-sync.sh"
  ],
  "scripts": {
    "start": "node service/bin/huhaa-myskills.mjs start",
    "scan": "node service/bin/huhaa-myskills.mjs scan",
    "stats": "node service/bin/huhaa-myskills.mjs stats",
    "duplicates": "node service/bin/huhaa-myskills.mjs duplicates",
    "init": "node service/bin/huhaa-myskills.mjs init",
    "purge": "node service/bin/huhaa-myskills.mjs purge",
    "dev": "node service/bin/huhaa-myskills.mjs dev",
    "sync": "bash service/scripts/sync-skills.sh",
    "sync:remote": "curl -fsSL https://raw.githubusercontent.com/aquarkgn/HuHaa-MySkills/main/install-and-sync.sh | bash -s -- --sync-only",
    "build:web": "node service/scripts/build-web.mjs",
    "test": "node --test service/packages/scanner/test/*.test.mjs service/packages/server/test/*.test.mjs",
    "verify": "node service/scripts/verify.mjs"
  },
  "dependencies": {
    "@huhaa/scanner": "file:service/packages/scanner",
    "@huhaa/server": "file:service/packages/server",
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.2",
    "fastify": "^5.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@huhaa/web": "file:service/packages/web",
    "@vitejs/plugin-vue": "^5.2.1",
    "fuse.js": "^7.0.0",
    "markdown-it": "^14.1.0",
    "pinia": "^2.3.0",
    "vite": "^6.0.0",
    "vue": "^3.5.13"
  }
}
