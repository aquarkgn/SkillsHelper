{
  "name": "huhaa-myskills",
  "version": "0.3.3",
  "private": false,
  "description": "Local skill / plugin / MCP aggregation hub. Browse all your AI agent skills at http://localhost:11520.",
  "license": "MIT",
  "homepage": "https://github.com/aquarkgn/HuHaa-MySkills#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aquarkgn/HuHaa-MySkills.git"
  },
  "bugs": {
    "url": "https://github.com/aquarkgn/HuHaa-MySkills/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "huhaa-myskills": "bin/huhaa-myskills.mjs"
  },
  "files": [
    "bin/",
    "build/",
    "config/",
    "packages/",
    "scripts/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node bin/huhaa-myskills.mjs start",
    "stop": "node bin/huhaa-myskills.mjs stop",
    "restart": "node bin/huhaa-myskills.mjs restart",
    "scan": "node bin/huhaa-myskills.mjs scan",
    "stats": "node bin/huhaa-myskills.mjs stats",
    "duplicates": "node bin/huhaa-myskills.mjs duplicates",
    "init": "node bin/huhaa-myskills.mjs init",
    "purge": "node bin/huhaa-myskills.mjs purge",
    "uninstall": "node bin/huhaa-myskills.mjs uninstall",
    "dev": "cd packages/web && npm run dev",
    "dev-bg": "bash scripts/start-dev.sh",
    "sync": "node bin/huhaa-myskills.mjs sync",
    "build:web": "node build/build-web.mjs",
    "typecheck:web": "tsc --noEmit -p packages/web/tsconfig.json",
    "test:web": "vitest run --root packages/web",
    "prepack": "node build/build-web.mjs",
    "test": "node --test packages/scanner/test/*.test.mjs packages/server/test/*.test.mjs",
    "verify": "node build/verify.mjs",
    "release": "npm version patch && git push --follow-tags"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "fast-glob": "^3.3.2",
    "fastify": "^5.0.0",
    "google-translate-api-x": "^10.7.3",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.0.0",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.460.0",
    "markdown-it": "^14.1.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.9"
  }
}
